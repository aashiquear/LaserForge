<?xml version="1.0" encoding="utf-8"?>
<!--
  LaserForge launcher icon background.
  Replaces the original flat #1A1A2E with a 135° gradient using the same palette
  as bg_gradient.xml (bg_start -> bg_mid -> bg_end) so the launcher matches the
  app's splash and main window background.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="@color/bg_start"
        android:centerColor="@color/bg_mid"
        android:endColor="@color/bg_end" />
</shape>
